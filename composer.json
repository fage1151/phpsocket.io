{
    "name": "php-socketio/server",
    "description": "Socket.IO v4 compatible server based on Workerman",
    "type": "library",
    "keywords": ["socket.io", "websocket", "workerman", "realtime", "real-time"],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "workerman/workerman": "^4.1",
        "psr/log": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhpSocketIO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSocketIO\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php server.php start",
        "start-daemon": "php server.php start -d",
        "stop": "php server.php stop",
        "restart": "php server.php restart",
        "status": "php server.php status",
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
