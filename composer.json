{
    "name": "php-socketio/server",
    "description": "Socket.IO v4 compatible server based on Workerman",
    "type": "library",
    "keywords": ["socket.io", "websocket", "workerman", "realtime", "real-time"],
    "license": "MulanPSL-2.0",
    "require": {
        "php": ">=8.1",
        "workerman/workerman": "^4.1 || ^5.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "suggest": {
        "workerman/channel": "使用 ClusterAdapter 进行集群通信",
        "workerman/redis": "使用 RedisAdapter 进行集群通信"
    },
    "autoload": {
        "psr-4": {
            "PhpSocketIO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpSocketIO\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php examples/server.php start",
        "start-daemon": "php examples/server.php start -d",
        "stop": "php examples/server.php stop",
        "restart": "php examples/server.php restart",
        "status": "php examples/server.php status",
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyse": "phpstan analyse",
        "check-all": [
            "@cs-check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
